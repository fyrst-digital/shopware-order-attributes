<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <!-- Entity Definitions -->
        <service id="Fyrst\OrderAttributes\Core\Content\OrderLineItemAttribute\OrderLineItemAttributeDefinition">
            <tag name="shopware.entity.definition" entity="fyrst_order_line_item_attribute"/>
        </service>

        <service id="Fyrst\OrderAttributes\Core\Content\OrderLineItemAttribute\Aggregate\OrderLineItemAttributeTranslation\OrderLineItemAttributeTranslationDefinition">
            <tag name="shopware.entity.definition" entity="fyrst_order_line_item_attribute_translation"/>
        </service>

        <!-- Subscribers -->
        <service id="Fyrst\OrderAttributes\Subscriber\Checkout">
            <argument type="service" id="fyrst_order_line_item_attribute.repository"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <!-- Controllers -->
        <service id="Fyrst\OrderAttributes\Controller\OrderAttributesController" public="true">
            <argument type="service" id="Shopware\Core\Checkout\Cart\SalesChannel\CartService"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>
    </services>
</container>
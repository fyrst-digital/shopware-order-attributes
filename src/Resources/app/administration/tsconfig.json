{
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM"
    ],
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "module": "es2022",
    "rootDirs": [
      "./src",
      "../../../../../../vendor/shopware/administration/Resources/app/administration/src",
      "../../../../../../vendor/shopware/administration/Resources/app/administration"
    ],
    "baseUrl": "./",
    "paths": {
      "src/*": [
        "../../../../../../../vendor/shopware/administration/Resources/app/administration/src/*"
      ],
      "@fyrst-order-attributes/*": [
        "./src/*"
      ]
    },
    "strict": false,
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "./src/**/*",
    "./src/types.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}